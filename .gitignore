# ── Dependencies ──
node_modules/
**/node_modules/

# ── Environment variables ──
.env
**/.env

# ── Build output ──
dist/
dist-ssr/
build/

# ── Logs ──
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

